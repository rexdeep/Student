<Window x:Class="StudentManagerApplication.Views.EditStudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Student"
        Height="350"
        Width="350">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Name" Grid.Row="0" Margin="5"/>
        <TextBox Grid.Row="0" Grid.Column="1"
                 Margin="5"
                 Text="{Binding TempStudent.Name}"/>

        <TextBlock Text="Age" Grid.Row="1" Margin="5"/>
        <TextBox Grid.Row="1" Grid.Column="1"
                 Margin="5"
                 Text="{Binding TempStudent.Age}"/>

        
        
        <TextBlock Text="Stream" Grid.Row="2" Margin="5"/>
        <TextBox Grid.Row="2" Grid.Column="1"
                 Margin="5"
                 Text="{Binding TempStudent.Stream}"/>

        <TextBlock Text="Total Fee" Grid.Row="3" Margin="5"/>
        <TextBox Grid.Row="3" Grid.Column="1"
                 Margin="5"
                 Text="{Binding TempStudent.TotalFee}"/>

        <TextBlock Text="Due Fee" Grid.Row="4" Margin="5"/>
        <TextBox Grid.Row="4" Grid.Column="1"
                 Margin="5"
                 Text="{Binding TempStudent.DueFee}"/>

        <StackPanel Grid.Row="5"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="10">

            <Button Content="Update"
                    Width="80"
                    Margin="5"
                    Command="{Binding Update}"
                     CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>

            <Button Content="Close"
                    Width="80"
                    Margin="5"
                    Command="{Binding Close}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>

        </StackPanel>

    </Grid>

</Window>